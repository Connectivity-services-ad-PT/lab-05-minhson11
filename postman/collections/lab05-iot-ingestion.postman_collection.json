{
  "info": {
    "name": "Lab 05 - IoT Ingestion API",
    "description": "Test collection for Lab 05 Docker Compose stack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has correct structure\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData).to.have.property('service');",
              "    pm.expect(jsonData).to.have.property('version');",
              "});",
              "",
              "pm.test(\"Service is healthy\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('ok');",
              "    pm.expect(jsonData.service).to.eql('iot-ingestion');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check if the API service is healthy"
      },
      "response": []
    },
    {
      "name": "Create Reading - Valid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has correct structure\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('reading_id');",
              "    pm.expect(jsonData).to.have.property('device_id');",
              "    pm.expect(jsonData).to.have.property('metric');",
              "    pm.expect(jsonData).to.have.property('accepted');",
              "    pm.expect(jsonData).to.have.property('created_at');",
              "});",
              "",
              "pm.test(\"Reading was accepted\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.accepted).to.be.true;",
              "    pm.collectionVariables.set(\"lastReadingId\", jsonData.reading_id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:30:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        },
        "description": "Create a valid sensor reading"
      },
      "response": []
    },
    {
      "name": "Create Reading - High Temperature",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Warning header is present\", function () {",
              "    pm.response.to.have.header('X-Warning');",
              "    pm.expect(pm.response.headers.get('X-Warning')).to.eql('high-temperature');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A02\",\n  \"metric\": \"temperature\",\n  \"value\": 75.0,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:35:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        },
        "description": "Create reading with high temperature to trigger warning"
      },
      "response": []
    },
    {
      "name": "Create Reading - Unauthorized",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401\", function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test(\"Response is problem+json\", function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json');",
              "});",
              "",
              "pm.test(\"Error details are correct\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(401);",
              "    pm.expect(jsonData.title).to.eql('Unauthorized');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 25.0,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-09T08:40:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        },
        "description": "Attempt to create reading without authorization token"
      },
      "response": []
    },
    {
      "name": "Get Latest Readings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has items array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('items');",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Items have correct structure\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.items.length > 0) {",
              "        var item = jsonData.items[0];",
              "        pm.expect(item).to.have.property('reading_id');",
              "        pm.expect(item).to.have.property('device_id');",
              "        pm.expect(item).to.have.property('metric');",
              "        pm.expect(item).to.have.property('value');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/latest?limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "latest"],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Get the latest sensor readings"
      },
      "response": []
    },
    {
      "name": "Get Reading by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Reading details are correct\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('reading_id');",
              "    pm.expect(jsonData).to.have.property('device_id');",
              "    pm.expect(jsonData).to.have.property('metric');",
              "    pm.expect(jsonData).to.have.property('value');",
              "    pm.expect(jsonData).to.have.property('timestamp');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/{{lastReadingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "{{lastReadingId}}"]
        },
        "description": "Get a specific reading by ID"
      },
      "response": []
    },
    {
      "name": "Get Reading by ID - Not Found",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Response is problem+json\", function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json');",
              "});",
              "",
              "pm.test(\"Error details are correct\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(404);",
              "    pm.expect(jsonData.title).to.eql('Not Found');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/R-20260609-9999",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "R-20260609-9999"]
        },
        "description": "Attempt to get a non-existent reading"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "lastReadingId",
      "value": ""
    }
  ]
}
